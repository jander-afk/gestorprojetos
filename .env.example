# ====== Banco ======
DATABASE_URL="postgresql://kanban:senha_forte@postgres:5432/kanban?schema=public"

# ====== Auth (NextAuth) ======
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-isto"
NEXTAUTH_URL="https://seu-dominio.com.br"

# ====== Redis / BullMQ ======
REDIS_URL="redis://redis:6379"

# ====== WhatsApp ======
# Provider ativo: "meta" (Cloud API oficial). Abstraído atrás de WhatsappProvider.
WHATSAPP_PROVIDER="meta"

# --- Meta Cloud API (Graph) ---
META_API_VERSION="v20.0"
# ID do número de telefone do WhatsApp Business (não é o número em si)
META_PHONE_NUMBER_ID="000000000000000"
# Token de acesso permanente do System User
META_ACCESS_TOKEN="EAAB..."
# Token que VOCÊ define; a Meta usa na verificação do webhook (GET)
META_WEBHOOK_VERIFY_TOKEN="defina-um-token-aleatorio"
# Idioma dos Message Templates aprovados
META_TEMPLATE_LOCALE="pt_BR"

# ====== App ======
# Fuso padrão usado quando o usuário não tiver definido o seu
APP_DEFAULT_TIMEZONE="America/Maceio"

# ====== Integração externa / conector MCP ======
# Chave usada pelos endpoints /api/ext/* (gere uma forte). 
API_TOKEN="troque-por-uma-chave-forte"
